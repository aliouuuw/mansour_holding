{
  "name": "@mansour/api",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run src/db/migrate.ts",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "bun run src/db/seed.ts"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.2.0",
    "@mansour/database": "workspace:*",
    "@mansour/domain": "workspace:*",
    "@mansour/shared": "workspace:*",
    "bcrypt": "^6.0.0",
    "better-auth": "^1.5.6",
    "drizzle-orm": "^0.30.0",
    "hono": "^4.1.0",
    "postgres": "^3.4.3",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^20.11.0",
    "dotenv": "^17.3.1",
    "drizzle-kit": "^0.20.14",
    "typescript": "^5.4.0"
  }
}
